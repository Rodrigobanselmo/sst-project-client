{
  "compilerOptions": {
    // Development optimizations - faster source maps
    "sourceMap": false,
    "module": "ESNext",
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true,
    "baseUrl": "src",
    "noImplicitAny": false,
    "jsx": "react-jsx",
    "incremental": true,
    // Path aliases for better module resolution
    "paths": {
      "@/*": [
        "./*"
      ],
      "@v2/*": [
        "./@v2/*"
      ],
      "components/*": [
        "./components/*"
      ],
      "core/*": [
        "./core/*"
      ],
      "layouts/*": [
        "./layouts/*"
      ],
      "store/*": [
        "./store/*"
      ],
      "configs/*": [
        "./configs/*"
      ],
      "assets/*": [
        "./assets/*"
      ],
      "project/*": [
        "./project/*"
      ],
      "polyfills/*": [
        "./polyfills/*"
      ],
      "json/*": [
        "./json/*"
      ]
    },
    // Additional optimizations
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist"
  ]
}
